---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import IconGitHub from '../components/IconGitHub.astro';
import IconLinkedIn from '../components/IconLinkedIn.astro';
import IconCV from '../components/IconCV.astro';

const cvUrl = "/CV-Miguel-Angel-Ramirez-Perez.pdf";

const rol = "Desarrollador Multiplataforma";
const descripcion = "Construyo productos digitales que funcionan en cualquier plataforma. Base sólida en programación, especializado en frontend con Astro, React y TypeScript, y expandiéndome hacia móvil con Kotlin Multiplatform.";
const canonicalURL = "https://marp0604.com/";
const ogImage = "https://marp0604.com/og-image.png";

const experiencia = [
  {
    empresa: "Farmacias.com",
    rol: "Desarrollador",
    periodo: "Feb. 2026 — Presente",
    ubicacion: "Aguadulce, Almería",
    descripcion: "Incorporado tras prácticas de formación dual. Mantenimiento, mejora y desarrollo de nuevas funcionalidades en plataforma e-commerce de farmacia. Trabajo en entorno de producto real, enfocado en calidad de código y estabilidad.",
    actual: true,
  },
  {
    empresa: "Adelantia IT Solutions",
    rol: "Técnico en prácticas",
    periodo: "Mar. 2022 — Jun. 2022",
    ubicacion: "Almería",
    descripcion: "Prácticas de ciclo medio en empresa de servicios IT. Administración y mantenimiento de equipos, instalación de sistemas operativos, configuración de redes y soporte técnico. Primer contacto profesional con entornos reales de trabajo.",
    actual: false,
  },
];

const formacion = [
  {
    centro: "IES Celia Viñas",
    titulo: "Desarrollo de Aplicaciones Multiplataforma",
    kind: "CFGS · DAM",
    periodo: "2022 — 2025",
  },
  {
    centro: "IES Celia Viñas",
    titulo: "Sistemas Microinformáticos y Redes",
    kind: "CFGM · SMR",
    periodo: "2019 — 2022",
  },
];

const proyectos = [
  {
    titulo: "Vexelplaypro",
    descripcion: "Plataforma propia que empezó en web y va creciendo hacia móvil con Kotlin Multiplatform. Un proyecto real donde tomo todas las decisiones: producto, arquitectura y diseño.",
    tecnologias: ["React", "TypeScript", "KMP"],
    num: "01",
    wip: true,
    links: [
      { tipo: "web", label: "Ver web", url: "https://vexelplaypro.com" },
    ],
  },
  {
    titulo: "Rick & Morty App",
    descripcion: "App Android nativa en Kotlin que consume la Rick & Morty API: navegación por temporadas, listado de episodios y fichas de personajes con datos en tiempo real.",
    tecnologias: ["Kotlin", "Android", "REST API"],
    num: "02",
    wip: false,
    links: [
      { tipo: "repo", label: "Repositorio", url: "https://github.com/marp0604/APIRickYMorty" },
    ],
  },
  {
    titulo: "Gestión de Tareas",
    descripcion: "Aplicación de escritorio en Java con arquitectura MVC. Gestión de tareas organizadas por proyectos sobre MySQL, con interfaz en Swing.",
    tecnologias: ["Java", "MVC", "MySQL"],
    num: "03",
    wip: false,
    links: [
      { tipo: "repo", label: "Repositorio", url: "https://github.com/marp0604/GestionTareas" },
    ],
  },
  {
    titulo: "marp0604-portfolio",
    descripcion: "Este portfolio. Construido con Astro, animaciones CSS propias y fuentes auto-alojadas. Diseño de alto impacto visual sin una sola librería de componentes. Código abierto.",
    tecnologias: ["Astro", "CSS", "TypeScript"],
    num: "04",
    wip: false,
    links: [
      { tipo: "repo", label: "Repositorio", url: "https://github.com/marp0604/marp0604-portfolio" },
      { tipo: "web", label: "Ver web", url: "https://marp0604.com" },
    ],
  },
];

const stackGrupos = [
  {
    categoria: "Frontend",
    skills: ["HTML", "CSS", "JavaScript", "TypeScript", "React", "Astro"],
  },
  {
    categoria: "Herramientas",
    skills: ["Git", "GitHub", "Vite", "Node.js", "npm"],
  },
  {
    categoria: "Explorando",
    skills: ["Kotlin Multiplatform", "Tailwind CSS", "Figma"],
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Miguel Ángel Ramírez Pérez",
  "url": canonicalURL,
  "jobTitle": "Desarrollador Multiplataforma",
  "description": descripcion,
  "knowsAbout": ["HTML", "CSS", "JavaScript", "TypeScript", "Astro", "React", "Node.js", "Git", "Kotlin Multiplatform"],
  "nationality": "ES",
  "sameAs": ["https://github.com/marp0604", "https://linkedin.com/in/marp0604"],
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Miguel Ángel Ramírez Pérez — {rol} · España</title>
    <meta name="description" content={descripcion} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <meta name="theme-color" content="#141519" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`Miguel Ángel Ramírez Pérez — ${rol}`} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="marp0604.com" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`Miguel Ángel Ramírez Pérez — ${rol}`} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>

    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <header>
      <nav aria-label="Navegación principal" id="nav">
        <a href="/" class="nav-logo" aria-label="Inicio — Miguel Ángel Ramírez">
          <span class="dot" aria-hidden="true"></span>
          marp<span class="slash" aria-hidden="true">/</span><span class="num">0604</span>
        </a>
        <ul class="nav-links" role="list">
          <li><a href="#sobre-mi">Sobre mí</a></li>
          <li><a href="#experiencia">Experiencia</a></li>
          <li><a href="#formacion">Formación</a></li>
          <li><a href="#proyectos">Proyectos</a></li>
          <li><a href="#stack">Stack</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
        <a href="#contacto" class="nav-available">
          <span class="dot" aria-hidden="true"></span>
          Disponible
        </a>
        <button
          class="nav-hamburger"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="nav-mobile-overlay"
          id="nav-hamburger-btn"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </nav>
    </header>

    <div
      id="nav-mobile-overlay"
      class="nav-mobile-overlay"
      role="dialog"
      aria-label="Menú de navegación"
      aria-modal="true"
    >
      <ul class="nav-mobile-links" role="list">
        <li><a href="#sobre-mi" class="nav-mobile-link">Sobre mí</a></li>
        <li><a href="#experiencia" class="nav-mobile-link">Experiencia</a></li>
        <li><a href="#formacion" class="nav-mobile-link">Formación</a></li>
        <li><a href="#proyectos" class="nav-mobile-link">Proyectos</a></li>
        <li><a href="#stack" class="nav-mobile-link">Stack</a></li>
        <li><a href="#contacto" class="nav-mobile-link">Contacto</a></li>
      </ul>
      <div class="nav-mobile-footer">
        <a href="https://github.com/marp0604" target="_blank" rel="noopener noreferrer" aria-label="GitHub (abre en nueva pestaña)">
          <IconGitHub />
          GitHub
        </a>
        <a href="https://linkedin.com/in/marp0604" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn (abre en nueva pestaña)">
          <IconLinkedIn />
          LinkedIn
        </a>
        <a href={cvUrl} download aria-label="Descargar CV en PDF">
          <IconCV />
          CV
        </a>
      </div>
    </div>

    <main id="main-content">

      <section class="hero" aria-label="Presentación" id="top">
        <div class="bg-glow" aria-hidden="true"></div>
        <div class="bg-grid" aria-hidden="true"></div>
        <div class="glow-blob" aria-hidden="true"></div>
        <div class="container">
          <p class="eyebrow reveal">
            <span class="rule" aria-hidden="true"></span>
            <span>Miguel Ángel Ramírez Pérez · <span class="lime">Desarrollador Multiplataforma</span></span>
          </p>
          <h1 class="hero-title reveal">
            Construyo
            <span class="accent">productos.</span>
          </h1>
          <div class="hero-lower reveal">
            <p class="hero-desc">
              Frontend sólido, arquitectura pensada. Del web al móvil con <strong>Kotlin Multiplatform</strong>. Desde Almería, España.
            </p>
            <div class="hero-actions">
              <a href="#proyectos" class="btn btn-primary">
                Ver proyectos
                <span class="arrow" aria-hidden="true">↗</span>
              </a>
              <a href="#contacto" class="btn btn-ghost">Contactar</a>
            </div>
          </div>
          <div class="hero-foot reveal" aria-hidden="true">
            <span class="hero-scroll">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
              Scroll
            </span>
            <span class="hero-coords">Almería · 36.83°N 2.46°W</span>
          </div>
        </div>
      </section>

      <div class="container">

        <section class="section" id="sobre-mi" aria-labelledby="title-sobre-mi">
          <p class="section-eyebrow reveal"><span class="rule" aria-hidden="true"></span><span id="title-sobre-mi">01 — Sobre mí</span></p>
          <div class="about-grid">
            <div class="about-photo reveal">
              <img
                src="/perfil.jpg"
                alt="Miguel Ángel Ramírez Pérez — Desarrollador Multiplataforma"
                width="340"
                height="453"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="reveal">
              <p class="about-statement">
                Escribo código como quien afina un <em>instrumento</em>: buscando el gesto justo, sin ruido.
              </p>
              <div class="about-bio">
                <p>
                  Estudié DAM en el IES Celia Viñas de Almería. Aprendí a programar de verdad: algoritmos, estructuras de datos, lógica sin atajos. Después aterricé en el frontend, donde esa base importa más.
                </p>
                <p>
                  Hoy trabajo en Farmacias.com sobre un e-commerce real y en paralelo desarrollo Vexelplaypro, mi proyecto propio, que ya camina hacia móvil con Kotlin Multiplatform.
                </p>
              </div>
              <div class="about-quick">
                <div class="about-quick-row">
                  <span class="about-quick-key">Rol</span>
                  <span class="about-quick-val">Desarrollador Multiplataforma</span>
                </div>
                <div class="about-quick-row">
                  <span class="about-quick-key">Stack</span>
                  <span class="about-quick-val">Astro · React · TypeScript · KMP</span>
                </div>
                <div class="about-quick-row">
                  <span class="about-quick-key">Ubicación</span>
                  <span class="about-quick-val">Almería, España</span>
                </div>
                <div class="about-quick-row">
                  <span class="about-quick-key">Empresa</span>
                  <span class="about-quick-val">Farmacias.com · Presente</span>
                </div>
                <div class="about-quick-row">
                  <span class="about-quick-key">Email</span>
                  <span class="about-quick-val" id="email-display">
                    <noscript><a href="mailto:contacto&#64;marp0604&#46;com">contacto&#64;marp0604&#46;com</a></noscript>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="experiencia" aria-labelledby="title-experiencia">
          <p class="section-eyebrow reveal"><span class="rule" aria-hidden="true"></span><span id="title-experiencia">02 — Experiencia</span></p>
          <div class="exp-list">
            {experiencia.map((e) => (
              <article class="exp-card reveal">
                <div class="exp-meta">
                  <span class="exp-date">{e.periodo}</span>
                  <span class="exp-place">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    {e.ubicacion}
                  </span>
                </div>
                <div>
                  <h3 class="exp-empresa">
                    {e.empresa}
                    {e.actual && (
                      <span class="badge-actual"><span class="dot" aria-hidden="true"></span>Actual</span>
                    )}
                  </h3>
                  <p class="exp-rol">{e.rol}</p>
                  <p class="exp-desc">{e.descripcion}</p>
                </div>
                <span class="exp-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
                </span>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="formacion" aria-labelledby="title-formacion">
          <p class="section-eyebrow reveal"><span class="rule" aria-hidden="true"></span><span id="title-formacion">03 — Formación</span></p>
          <div class="edu-grid">
            {formacion.map((f) => (
              <article class="edu-card reveal">
                <p class="edu-kind">{f.kind}</p>
                <h3 class="edu-titulo">{f.titulo}</h3>
                <div class="edu-foot">
                  <span>{f.centro}</span>
                  <span class="date">{f.periodo}</span>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="proyectos" aria-labelledby="title-proyectos">
          <p class="section-eyebrow reveal"><span class="rule" aria-hidden="true"></span><span id="title-proyectos">04 — Proyectos</span></p>
          <div class="proyecto-list">
            {proyectos.map((p) => (
              <article class="proyecto-item reveal">
                <span class="proyecto-num" aria-hidden="true">{p.num}</span>
                <div>
                  <div class="proyecto-title-row">
                    <span class="proyecto-name">{p.titulo}</span>
                    {p.wip && <span class="proyecto-badge">En progreso</span>}
                  </div>
                  <p class="proyecto-desc">{p.descripcion}</p>
                  <div class="proyecto-tags">
                    {p.tecnologias.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  <div class="proyecto-links">
                    {p.links.map((l) => (
                      <a
                        href={l.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="proyecto-link"
                        aria-label={`${l.label} de ${p.titulo} (abre en nueva pestaña)`}
                      >
                        {l.tipo === "repo" && <IconGitHub />}
                        <span>{l.label}</span>
                        <span class="arrow" aria-hidden="true">↗</span>
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="stack" aria-labelledby="title-stack">
          <p class="section-eyebrow reveal"><span class="rule" aria-hidden="true"></span><span id="title-stack">05 — Stack</span></p>
          <div class="stack-grid">
            {stackGrupos.map((g) => (
              <div class="stack-card reveal">
                <p class="stack-label"><span class="dot" aria-hidden="true"></span>{g.categoria}</p>
                <ul class="stack-items" role="list">
                  {g.skills.map((s) => (
                    <li class={g.categoria === "Explorando" ? "is-explore" : ""}>
                      <span>{s}</span>
                      <span class="sig" aria-hidden="true">///</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>

      </div>

      <section class="contact" id="contacto" aria-labelledby="title-contacto">
        <div class="bg-glow" aria-hidden="true"></div>
        <div class="bg-grid" aria-hidden="true"></div>
        <div class="glow-blob" aria-hidden="true"></div>
        <div class="container">
          <p class="section-eyebrow reveal"><span class="rule" aria-hidden="true"></span><span>06 — Contacto</span></p>
          <h2 class="contact-title reveal" id="title-contacto">
            Hablemos de
            <span class="accent">tu proyecto.</span>
          </h2>
          <p class="contact-desc reveal">
            Abierto a colaboraciones, oportunidades interesantes o simplemente para intercambiar ideas sobre producto y frontend.
          </p>
          <div class="contact-actions reveal">
            <button id="contact-btn" class="contact-email" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <span id="contact-btn-text">Enviar email</span>
              <span class="arrow" aria-hidden="true">↗</span>
            </button>
            <noscript>
              <a class="contact-email" href="mailto:contacto&#64;marp0604&#46;com">
                contacto&#64;marp0604&#46;com
                <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </noscript>
            <a
              href="https://linkedin.com/in/marp0604"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost"
              aria-label="LinkedIn (abre en nueva pestaña)"
            >
              <IconLinkedIn size={16} />
              LinkedIn
            </a>
            <a
              href="https://github.com/marp0604"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-ghost"
              aria-label="GitHub (abre en nueva pestaña)"
            >
              <IconGitHub size={16} />
              GitHub
            </a>
            <a href={cvUrl} download class="btn btn-ghost" aria-label="Descargar CV en PDF">
              <IconCV size={16} />
              Descargar CV
            </a>
          </div>
        </div>
      </section>

    </main>

    <footer>
      <div class="container">
        <div class="footer-grid">
          <span>© 2026 Miguel Ángel Ramírez Pérez</span>
          <span class="footer-mid">hecho con <span class="footer-heart" aria-label="amor">♥</span> en Almería</span>
          <a
            href="https://github.com/marp0604/marp0604-portfolio"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-src"
            aria-label="Código fuente en GitHub (abre en nueva pestaña)"
          >
            <IconGitHub />
            Ver código fuente
          </a>
        </div>
      </div>
    </footer>

    <script>
      import '../scripts/main.js';
    </script>

  </body>
</html>
