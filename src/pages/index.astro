---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Miguel Ángel Ramírez Pérez — {rol} · España</title>
    <meta name="description" content={descripcion} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- FIX 1: theme-color para barra del navegador en móvil -->
    <meta name="theme-color" content="#080808" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`Miguel Ángel Ramírez Pérez — ${rol}`} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="marp0604.com" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`Miguel Ángel Ramírez Pérez — ${rol}`} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Cabinet Grotesk (Fontshare) — display · bold, readable, less overexposed than Syne -->
    <link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@700,800,900&f[]=satoshi@400,500,600&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:           #080808;
        --surface:      #111111;
        --surface-2:    #161616;
        --border:       rgba(255,255,255,0.07);
        --border-hover: rgba(255,255,255,0.18);
        --text:         #f2f0ec;
        --muted:        #a0a09a;
        --faint:        #555552;
        --accent:       #c8f060;
        --accent2:      #60d0f0;
        --font-body:    'Satoshi', system-ui, sans-serif;
        --font-display: 'Cabinet Grotesk', sans-serif;
        --ease:         cubic-bezier(0.16, 1, 0.3, 1);
        --text-xs:      clamp(0.75rem,  0.7rem  + 0.25vw, 0.8125rem);
        --text-sm:      clamp(0.875rem, 0.85rem + 0.25vw, 0.9375rem);
        --text-base:    clamp(1rem,     0.95rem + 0.25vw, 1.0625rem);
        --text-lg:      clamp(1.125rem, 1rem    + 0.5vw,  1.375rem);
        --text-hero:    clamp(3.5rem,   0.5rem  + 8vw,    9rem);
      }

      html {
        /* FIX 2: smooth scroll solo donde está soportado nativamente (Safari fix) */
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        scroll-padding-top: 5rem;
        cursor: none;
      }

      @supports (scroll-behavior: smooth) {
        html { scroll-behavior: smooth; }
      }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--text);
        font-size: var(--text-base);
        line-height: 1.7;
        overflow-x: hidden;
      }

      .skip-link {
        position: absolute; top: -100%; left: 1rem;
        background: var(--accent); color: #060606;
        padding: 0.5rem 1rem; border-radius: 0 0 4px 4px;
        font-weight: 700; font-size: var(--text-sm);
        text-decoration: none; z-index: 10000;
        transition: top 200ms;
      }
      .skip-link:focus { top: 0; }

      #cursor {
        position: fixed; width: 10px; height: 10px;
        background: var(--accent); border-radius: 50%;
        pointer-events: none; z-index: 9999;
        transform: translate(-50%,-50%);
        transition: width 300ms var(--ease), height 300ms var(--ease);
        mix-blend-mode: difference;
      }
      #cursor-ring {
        position: fixed; width: 36px; height: 36px;
        border: 1.5px solid rgba(200,240,96,0.45); border-radius: 50%;
        pointer-events: none; z-index: 9998;
        transform: translate(-50%,-50%);
        transition: width 300ms var(--ease), height 300ms var(--ease);
      }
      body:has(a:hover) #cursor,
      body:has(button:hover) #cursor { width: 18px; height: 18px; }
      body:has(a:hover) #cursor-ring,
      body:has(button:hover) #cursor-ring { width: 56px; height: 56px; }

      #hero-canvas {
        position: fixed; top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none; z-index: 0; opacity: 0.22;
      }

      /* ── NAV ── */
      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        display: flex; justify-content: space-between; align-items: center;
        padding: 1.5rem 3rem;
        background: rgba(8,8,8,0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
      }
      .nav-logo {
        font-family: var(--font-display); font-size: var(--text-base);
        font-weight: 900; color: var(--text);
        text-decoration: none; letter-spacing: 0.08em; text-transform: uppercase;
      }
      .nav-links { display: flex; gap: 2.5rem; list-style: none; align-items: center; }
      .nav-links a {
        color: var(--muted); text-decoration: none;
        font-size: var(--text-sm); letter-spacing: 0.08em;
        text-transform: uppercase; font-weight: 500;
        transition: color 200ms;
      }
      .nav-links a:hover { color: var(--text); }
      .nav-github {
        display: flex; align-items: center; gap: 0.4rem;
        border: 1px solid var(--border);
        padding: 0.35rem 0.9rem; border-radius: 999px;
        text-transform: none !important; letter-spacing: 0 !important;
        transition: border-color 200ms, color 200ms !important;
      }
      .nav-github:hover { border-color: var(--border-hover) !important; color: var(--text) !important; }

      /* Hamburger button */
      .nav-hamburger {
        display: none;
        flex-direction: column; justify-content: center; align-items: center;
        gap: 5px; width: 40px; height: 40px;
        background: none; border: none; cursor: pointer;
        padding: 0; z-index: 200;
      }
      .nav-hamburger span {
        display: block; width: 22px; height: 1.5px;
        background: var(--text);
        transition: transform 300ms var(--ease), opacity 200ms;
        transform-origin: center;
      }
      .nav-hamburger[aria-expanded="true"] span:nth-child(1) {
        transform: translateY(6.5px) rotate(45deg);
      }
      .nav-hamburger[aria-expanded="true"] span:nth-child(2) {
        opacity: 0; transform: scaleX(0);
      }
      .nav-hamburger[aria-expanded="true"] span:nth-child(3) {
        transform: translateY(-6.5px) rotate(-45deg);
      }

      /* Mobile overlay menu */
      .nav-mobile-overlay {
        display: none;
        position: fixed; inset: 0; z-index: 150;
        background: rgba(8,8,8,0.97);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        flex-direction: column; justify-content: center; align-items: center;
        gap: 0;
        opacity: 0;
        transition: opacity 300ms var(--ease);
      }
      .nav-mobile-overlay.open {
        display: flex;
        opacity: 1;
      }
      .nav-mobile-links {
        list-style: none;
        display: flex; flex-direction: column;
        align-items: center; gap: 0;
        width: 100%;
      }
      .nav-mobile-links li {
        width: 100%;
        border-bottom: 1px solid var(--border);
      }
      .nav-mobile-links li:first-child {
        border-top: 1px solid var(--border);
      }
      .nav-mobile-links a {
        display: block;
        text-align: center;
        padding: 1.5rem 2rem;
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 5vw, 2rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--muted);
        text-decoration: none;
        text-transform: uppercase;
        transition: color 200ms, background 200ms;
      }
      .nav-mobile-links a:hover,
      .nav-mobile-links a:focus { color: var(--text); background: rgba(200,240,96,0.04); }
      .nav-mobile-footer {
        margin-top: 2.5rem;
        display: flex; gap: 1rem; justify-content: center;
      }
      .nav-mobile-footer a {
        font-size: var(--text-sm); color: var(--muted);
        text-decoration: none; border: 1px solid var(--border);
        padding: 0.5rem 1.25rem; border-radius: 999px;
        display: flex; align-items: center; gap: 0.4rem;
        transition: color 200ms, border-color 200ms;
      }
      .nav-mobile-footer a:hover { color: var(--text); border-color: var(--border-hover); }

      /* ── HERO ── */
      .hero {
        position: relative; z-index: 1;
        min-height: 100vh;
        display: flex; flex-direction: column; justify-content: flex-end;
        padding: 0 3rem 5rem;
        max-width: 1400px; margin: 0 auto;
      }
      .hero-eyebrow {
        font-size: var(--text-sm); letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--accent);
        font-weight: 600; margin-bottom: 1.5rem;
        opacity: 0; transform: translateY(16px);
        transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
      }
      .hero-title {
        font-family: var(--font-display);
        font-size: var(--text-hero);
        font-weight: 900; line-height: 0.95;
        letter-spacing: -0.04em; color: var(--text);
        margin-bottom: 2.5rem;
        opacity: 0; transform: translateY(16px);
        transition: opacity 0.7s 0.15s var(--ease), transform 0.7s 0.15s var(--ease);
      }
      .hero-bottom {
        display: flex; justify-content: space-between;
        align-items: flex-end; gap: 2rem; flex-wrap: wrap;
        opacity: 0; transform: translateY(16px);
        transition: opacity 0.7s 0.3s var(--ease), transform 0.7s 0.3s var(--ease);
      }
      .hero-eyebrow.show, .hero-title.show, .hero-bottom.show {
        opacity: 1; transform: translateY(0);
      }
      .hero-title .line2 {
        display: block;
        -webkit-text-stroke: 1.5px rgba(255,255,255,0.4);
        color: transparent;
        transition: color 400ms, -webkit-text-stroke 400ms;
      }
      .hero-title .line2:hover { color: var(--text); -webkit-text-stroke: 0px; }
      .hero-title .accent { color: var(--accent); }
      .hero-desc {
        font-size: var(--text-base); color: var(--text);
        max-width: 400px; line-height: 1.8; opacity: 0.72;
      }
      .hero-scroll {
        display: flex; flex-direction: column;
        align-items: center; gap: 0.5rem;
        color: var(--muted); font-size: var(--text-xs);
        letter-spacing: 0.15em; text-transform: uppercase; font-weight: 500;
      }
      .scroll-line {
        width: 1px; height: 60px;
        background: linear-gradient(to bottom, var(--accent), transparent);
        animation: scrollPulse 2.5s ease-in-out infinite;
      }

      .marquee-wrap {
        position: relative; z-index: 1;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        overflow: hidden; padding: 1.1rem 0;
        background: var(--surface);
      }
      .marquee-track {
        display: flex; gap: 4rem; white-space: nowrap; width: max-content;
        animation: marquee 100s linear infinite;
      }
      .marquee-track:hover { animation-play-state: paused; }
      .marquee-item {
        font-family: var(--font-display);
        font-size: var(--text-sm); font-weight: 700;
        letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted);
        display: flex; align-items: center; gap: 4rem;
      }
      .marquee-item::after {
        content: ''; width: 4px; height: 4px; border-radius: 50%;
        background: var(--accent); flex-shrink: 0; display: inline-block;
      }

      .content {
        position: relative; z-index: 1;
        max-width: 1400px; margin: 0 auto; padding: 0 3rem;
      }
      .section { padding: 8rem 0; border-top: 1px solid var(--border); }
      .section-header {
        display: flex; justify-content: space-between;
        align-items: baseline; margin-bottom: 5rem;
      }
      .section-num {
        font-family: var(--font-display); font-size: var(--text-xs);
        color: var(--muted); letter-spacing: 0.12em;
        font-weight: 700; text-transform: uppercase;
      }
      .section-title {
        font-family: var(--font-display);
        font-size: clamp(2.25rem, 5vw, 4.5rem);
        font-weight: 900; letter-spacing: -0.03em;
        color: var(--text); line-height: 1;
      }

      .about-grid {
        display: grid; grid-template-columns: 1.1fr 0.9fr;
        gap: 6rem; align-items: start;
      }
      .about-statement {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 2.5vw, 2.125rem);
        font-weight: 700; line-height: 1.35;
        color: var(--text); letter-spacing: -0.02em;
        margin-bottom: 2rem;
      }
      .about-statement em { color: var(--accent); font-style: normal; }
      .about-bio {
        /* FIX 3: eliminado max-width fijo, el grid ya controla el ancho */
        font-size: var(--text-base); color: var(--muted);
        line-height: 1.85;
        margin-bottom: 2.5rem;
      }
      .about-links { display: flex; gap: 1rem; flex-wrap: wrap; }
      .about-link {
        display: inline-flex; align-items: center; gap: 0.45rem;
        font-size: var(--text-sm); font-weight: 600;
        color: var(--muted); text-decoration: none;
        border: 1px solid var(--border);
        padding: 0.5rem 1.1rem; border-radius: 999px;
        transition: color 200ms, border-color 200ms;
      }
      .about-link:hover { color: var(--text); border-color: var(--border-hover); }
      .about-details { display: flex; flex-direction: column; }
      .about-detail-item {
        display: grid; grid-template-columns: 120px 1fr;
        gap: 1.5rem; align-items: baseline;
        padding: 1.1rem 0; border-top: 1px solid var(--border);
      }
      .about-detail-item:last-child { border-bottom: 1px solid var(--border); }
      .about-detail-label {
        font-size: var(--text-xs); letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--faint); font-weight: 600;
      }
      .about-detail-value {
        font-size: var(--text-sm); color: var(--text); font-weight: 500; line-height: 1.5;
      }
      .about-detail-value a {
        color: var(--accent); text-decoration: none; transition: opacity 200ms;
      }
      .about-detail-value a:hover { opacity: 0.75; }

      .exp-list { display: flex; flex-direction: column; }
      .exp-item {
        display: grid; grid-template-columns: 1fr 200px;
        gap: 3rem; padding: 3rem 0;
        border-top: 1px solid var(--border); align-items: start;
      }
      .exp-item:last-child { border-bottom: 1px solid var(--border); }
      .exp-empresa {
        font-family: var(--font-display);
        font-size: clamp(1.25rem, 2vw, 1.625rem);
        font-weight: 800; color: var(--text);
        letter-spacing: -0.025em; margin-bottom: 0.3rem;
      }
      .exp-rol {
        font-size: var(--text-sm); color: var(--accent);
        font-weight: 600; margin-bottom: 1rem;
      }
      .exp-desc {
        font-size: var(--text-base); color: var(--muted);
        line-height: 1.8; max-width: 52ch;
      }
      .exp-meta { text-align: right; }
      .exp-periodo {
        font-size: var(--text-sm); color: var(--muted);
        font-weight: 500; font-variant-numeric: tabular-nums;
        margin-bottom: 0.35rem; display: block;
      }
      .exp-ubicacion { font-size: var(--text-xs); color: var(--faint); letter-spacing: 0.06em; }

      /* Formación */
      .edu-list { display: flex; flex-direction: column; }
      .edu-item {
        display: grid; grid-template-columns: 1fr 160px;
        gap: 3rem; padding: 2.25rem 0;
        border-top: 1px solid var(--border); align-items: baseline;
      }
      .edu-item:last-child { border-bottom: 1px solid var(--border); }
      .edu-titulo {
        font-family: var(--font-display);
        font-size: clamp(1rem, 1.5vw, 1.25rem);
        font-weight: 700; color: var(--text);
        letter-spacing: -0.02em; margin-bottom: 0.2rem;
      }
      .edu-centro {
        font-size: var(--text-sm); color: var(--muted); font-weight: 500;
      }
      .edu-periodo {
        font-size: var(--text-sm); color: var(--muted);
        font-variant-numeric: tabular-nums; text-align: right;
      }

      .proyecto-item {
        display: grid; grid-template-columns: 64px 1fr 2rem;
        gap: 3rem; align-items: center;
        padding: 2.5rem 0; border-top: 1px solid var(--border);
        text-decoration: none; position: relative; overflow: hidden;
      }
      .proyecto-item:last-child { border-bottom: 1px solid var(--border); }
      .proyecto-item::after {
        content: ''; position: absolute;
        bottom: 0; left: 0; right: 0; height: 1px;
        background: var(--accent);
        transform: scaleX(0); transform-origin: left;
        transition: transform 400ms var(--ease);
      }
      .proyecto-item:hover::after { transform: scaleX(1); }
      .proyecto-item:hover .proyecto-num { color: var(--accent); }
      .proyecto-item:hover .proyecto-arrow { transform: translate(3px,-3px); color: var(--accent); }
      .proyecto-num {
        font-family: var(--font-display); font-size: var(--text-sm);
        color: var(--muted); font-weight: 700; letter-spacing: 0.06em;
        transition: color 280ms; font-variant-numeric: tabular-nums;
      }
      .proyecto-title-row {
        display: flex; align-items: center;
        gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap;
      }
      .proyecto-name {
        font-family: var(--font-display);
        font-size: clamp(1.25rem, 2.5vw, 1.875rem);
        font-weight: 800; color: var(--text); letter-spacing: -0.025em;
      }
      .proyecto-badge {
        font-size: var(--text-xs); padding: 0.15rem 0.6rem;
        border-radius: 999px;
        background: rgba(200,240,96,0.1);
        border: 1px solid rgba(200,240,96,0.25);
        color: var(--accent); font-weight: 600; letter-spacing: 0.06em;
      }
      .proyecto-tags { display: flex; gap: 0.375rem; flex-wrap: wrap; margin-top: 0.25rem; }
      .tag {
        font-size: var(--text-xs); padding: 0.2rem 0.65rem;
        border-radius: 999px; border: 1px solid var(--border-hover);
        color: var(--muted); font-weight: 600; letter-spacing: 0.04em;
      }
      .proyecto-desc {
        font-size: var(--text-base); color: var(--muted);
        line-height: 1.7; max-width: 520px; margin-top: 0.6rem;
      }
      .proyecto-arrow {
        font-size: 1.25rem; color: var(--muted);
        transition: transform 280ms var(--ease), color 280ms;
        flex-shrink: 0; line-height: 1;
      }

      .stack-grupos {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;
      }
      .stack-grupo {
        padding: 2.5rem 2.5rem 2.5rem 0;
        border-top: 1px solid var(--border);
      }
      .stack-grupo:not(:first-child) {
        padding-left: 2.5rem;
        border-left: 1px solid var(--border);
      }
      .stack-grupo-label {
        font-size: var(--text-xs); letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--faint);
        font-weight: 700; margin-bottom: 1.25rem;
      }
      .stack-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
      .chip {
        font-size: var(--text-sm); font-weight: 500;
        padding: 0.45rem 1rem; border-radius: 999px;
        border: 1px solid var(--border);
        color: var(--text); background: var(--surface-2);
        transition: border-color 200ms;
      }
      .chip:hover { border-color: var(--border-hover); }
      .chip-accent {
        border-color: rgba(200,240,96,0.2);
        background: rgba(200,240,96,0.05);
        color: var(--accent);
      }
      .chip-accent:hover { border-color: rgba(200,240,96,0.5); }

      .contact-big {
        padding: 8rem 0 10rem; border-top: 1px solid var(--border);
        text-align: center;
      }
      .contact-overline {
        font-size: var(--text-sm); letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--accent);
        font-weight: 700; margin-bottom: 2.25rem;
      }
      .contact-title {
        font-family: var(--font-display);
        font-size: clamp(3rem, 8vw, 7rem);
        font-weight: 900; letter-spacing: -0.04em;
        line-height: 1; color: var(--text); margin-bottom: 3rem;
      }
      .contact-title span {
        display: block;
        -webkit-text-stroke: 1.5px rgba(255,255,255,0.35);
        color: transparent;
      }
      .contact-actions {
        display: flex; justify-content: center;
        align-items: center; gap: 1rem; flex-wrap: wrap;
      }
      .contact-email {
        display: inline-flex; align-items: center; gap: 0.875rem;
        font-family: var(--font-display); font-size: var(--text-lg);
        font-weight: 700; color: var(--text); text-decoration: none;
        border: 1.5px solid var(--border-hover);
        padding: 1.125rem 2.5rem; border-radius: 999px;
        transition: border-color 300ms, background 300ms, color 300ms;
        letter-spacing: -0.01em;
      }
      .contact-email:hover {
        border-color: var(--accent); background: var(--accent); color: #060606;
      }
      .contact-email .arrow { transition: transform 280ms var(--ease); }
      .contact-email:hover .arrow { transform: translate(3px,-3px); }
      .contact-linkedin {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: var(--text-base); font-weight: 600;
        color: var(--muted); text-decoration: none;
        border: 1px solid var(--border);
        padding: 1.125rem 2rem; border-radius: 999px;
        transition: border-color 300ms, color 300ms;
      }
      .contact-linkedin:hover { color: var(--text); border-color: var(--border-hover); }

      footer {
        position: relative; z-index: 1;
        border-top: 1px solid var(--border);
        padding: 2rem 3rem;
        display: flex; justify-content: space-between; align-items: center;
        font-size: var(--text-sm); color: var(--muted); letter-spacing: 0.04em;
      }
      .footer-github {
        display: flex; align-items: center; gap: 0.5rem;
        color: var(--muted); text-decoration: none; transition: color 200ms;
      }
      .footer-github:hover { color: var(--text); }

      .reveal {
        opacity: 0; transform: translateY(28px);
        transition: opacity 0.65s var(--ease), transform 0.65s var(--ease);
      }
      .reveal.visible { opacity: 1; transform: translateY(0); }

      @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      @keyframes scrollPulse {
        0%, 100% { opacity: 0.3; }
        50%       { opacity: 1; }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }

      @media (max-width: 900px) {
        .stack-grupos { grid-template-columns: 1fr 1fr; }
        .stack-grupo:nth-child(3) { border-left: none; padding-left: 0; }
      }

      @media (max-width: 768px) {
        nav { padding: 1.125rem 1.5rem; }
        .nav-links { display: none; }
        .nav-hamburger { display: flex; }
        .hero { padding: 0 1.5rem 4rem; }
        .content { padding: 0 1.5rem; }
        .about-grid { grid-template-columns: 1fr; gap: 3rem; }
        .exp-item { grid-template-columns: 1fr; gap: 0.75rem; }
        .exp-meta { text-align: left; }
        .edu-item { grid-template-columns: 1fr; gap: 0.4rem; }
        .edu-periodo { text-align: left; }
        .proyecto-item { grid-template-columns: 52px 1fr; gap: 1.5rem; }
        .proyecto-arrow { display: none; }
        .stack-grupos { grid-template-columns: 1fr; }
        .stack-grupo { padding: 2rem 0; border-left: none !important; }
        .contact-big { padding: 5rem 0 6rem; }
        footer { padding: 1.5rem; flex-direction: column; gap: 0.5rem; text-align: center; }
      }

      @media (max-width: 480px) {
        html { cursor: auto; }
        #cursor, #cursor-ring { display: none; }
      }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 3px;
      }
    </style>
  </head>
