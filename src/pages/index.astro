---
import '../styles/global.css';
import IconGitHub from '../components/IconGitHub.astro';
import IconLinkedIn from '../components/IconLinkedIn.astro';
import IconCV from '../components/IconCV.astro';

const cvUrl = "/CV-Miguel-Angel-Ramirez-Perez.pdf";

const rol = "Desarrollador Multiplataforma";
const descripcion = "Construyo productos digitales que funcionan en cualquier plataforma. Base sólida en programación, especializado en frontend con Astro, React y TypeScript, y expandiéndome hacia móvil con Kotlin Multiplatform.";
const canonicalURL = "https://marp0604.com/";
const ogImage = "https://marp0604.com/og-image.png";

const experiencia = [
  {
    empresa: "Farmacias.com",
    rol: "Desarrollador",
    periodo: "Feb. 2026 — Presente",
    ubicacion: "Aguadulce, Almería",
    descripcion: "Incorporado tras prácticas de formación dual. Mantenimiento, mejora y desarrollo de nuevas funcionalidades en plataforma e-commerce de farmacia. Trabajo en entorno de producto real, enfocado en calidad de código y estabilidad.",
  },
  {
    empresa: "Adelantia IT Solutions",
    rol: "Técnico en prácticas",
    periodo: "Mar. 2022 — Jun. 2022",
    ubicacion: "Almería",
    descripcion: "Prácticas de ciclo medio en empresa de servicios IT. Administración y mantenimiento de equipos, instalación de sistemas operativos, configuración de redes y soporte técnico. Primer contacto profesional con entornos reales de trabajo.",
  },
];

const formacion = [
  {
    centro: "IES Celia Viñas",
    titulo: "CFGS — Desarrollo de Aplicaciones Multiplataforma (DAM)",
    periodo: "2022 — 2025",
  },
  {
    centro: "IES Celia Viñas",
    titulo: "CFGM — Sistemas Microinformáticos y Redes (SMR)",
    periodo: "2019 — 2022",
  },
];

const proyectos = [
  {
    titulo: "Vexelplaypro",
    descripcion: "Plataforma propia que empezó en web y va creciendo hacia móvil con Kotlin Multiplatform. Un proyecto real donde tomo todas las decisiones: producto, arquitectura y diseño.",
    tecnologias: ["React", "TypeScript", "KMP"],
    num: "01",
    wip: true,
    links: [
      { tipo: "web", label: "Ver web", url: "https://vexelplaypro.com" },
    ],
  },
  {
    titulo: "Rick & Morty App",
    descripcion: "App Android nativa en Kotlin que consume la Rick & Morty API: navegación por temporadas, listado de episodios y fichas de personajes con datos en tiempo real.",
    tecnologias: ["Kotlin", "Android", "REST API"],
    num: "02",
    wip: false,
    links: [
      { tipo: "repo", label: "Repositorio", url: "https://github.com/marp0604/APIRickYMorty" },
    ],
  },
  {
    titulo: "Gestión de Tareas",
    descripcion: "Aplicación de escritorio en Java con arquitectura MVC. Gestión de tareas organizadas por proyectos sobre MySQL, con interfaz en Swing.",
    tecnologias: ["Java", "MVC", "MySQL"],
    num: "03",
    wip: false,
    links: [
      { tipo: "repo", label: "Repositorio", url: "https://github.com/marp0604/GestionTareas" },
    ],
  },
  {
    titulo: "marp0604-portfolio",
    descripcion: "Este portfolio. Construido con Astro, animaciones CSS propias y canvas. Diseño de alto impacto visual sin una sola librería de componentes. Código abierto.",
    tecnologias: ["Astro", "CSS", "TypeScript"],
    num: "04",
    wip: false,
    links: [
      { tipo: "repo", label: "Repositorio", url: "https://github.com/marp0604/marp0604-portfolio" },
      { tipo: "web", label: "Ver web", url: "https://marp0604.com" },
    ],
  },
];

const stackGrupos = [
  {
    categoria: "Frontend",
    skills: ["HTML", "CSS", "JavaScript", "TypeScript", "React", "Astro"],
  },
  {
    categoria: "Herramientas",
    skills: ["Git", "GitHub", "Vite", "Node.js", "npm"],
  },
  {
    categoria: "Explorando",
    skills: ["Kotlin Multiplatform", "Tailwind CSS", "Figma"],
  },
];

// Doble copia para que translateX(-50%) cierre el loop sin salto visible
const marqueeBase = ["Frontend", "Astro", "React", "TypeScript", "KMP", "CSS", "Multiplataforma", "Producto"];
const marqueeItems = [...marqueeBase, ...marqueeBase];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Miguel Ángel Ramírez Pérez",
  "url": canonicalURL,
  "jobTitle": "Desarrollador Multiplataforma",
  "description": descripcion,
  "knowsAbout": ["HTML", "CSS", "JavaScript", "TypeScript", "Astro", "React", "Node.js", "Git", "Kotlin Multiplatform"],
  "nationality": "ES",
  "sameAs": ["https://github.com/marp0604", "https://linkedin.com/in/marp0604"],
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Miguel Ángel Ramírez Pérez — {rol} · España</title>
    <meta name="description" content={descripcion} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <meta name="theme-color" content="#080808" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`Miguel Ángel Ramírez Pérez — ${rol}`} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="marp0604.com" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`Miguel Ángel Ramírez Pérez — ${rol}`} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@700,800,900&f[]=satoshi@400,500,600&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>

    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <div id="cursor" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true"></div>
    <canvas id="hero-canvas" aria-hidden="true"></canvas>

    <header>
      <nav aria-label="Navegación principal">
        <a href="/" class="nav-logo" aria-label="Inicio — Miguel Ángel">MA</a>
        <ul class="nav-links" role="list">
          <li><a href="#sobre-mi">Sobre mí</a></li>
          <li><a href="#experiencia">Experiencia</a></li>
          <li><a href="#proyectos">Proyectos</a></li>
          <li><a href="#stack">Stack</a></li>
          <li><a href="#contacto">Contacto</a></li>
          <li>
            <a
              href="https://github.com/marp0604"
              target="_blank"
              rel="noopener noreferrer"
              class="nav-github"
              aria-label="Perfil de GitHub (abre en nueva pestaña)"
            >
              <IconGitHub />
              GitHub
            </a>
          </li>
        </ul>
        <button
          class="nav-hamburger"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="nav-mobile-overlay"
          id="nav-hamburger-btn"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </nav>
    </header>

    <div
      id="nav-mobile-overlay"
      class="nav-mobile-overlay"
      role="dialog"
      aria-label="Menú de navegación"
      aria-modal="true"
    >
      <ul class="nav-mobile-links" role="list">
        <li><a href="#sobre-mi" class="nav-mobile-link">Sobre mí</a></li>
        <li><a href="#experiencia" class="nav-mobile-link">Experiencia</a></li>
        <li><a href="#proyectos" class="nav-mobile-link">Proyectos</a></li>
        <li><a href="#stack" class="nav-mobile-link">Stack</a></li>
        <li><a href="#contacto" class="nav-mobile-link">Contacto</a></li>
      </ul>
      <div class="nav-mobile-footer">
        <a href="https://github.com/marp0604" target="_blank" rel="noopener noreferrer" aria-label="GitHub (abre en nueva pestaña)">
          <IconGitHub />
          GitHub
        </a>
        <a href="https://linkedin.com/in/marp0604" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn (abre en nueva pestaña)">
          <IconLinkedIn />
          LinkedIn
        </a>
        <a href={cvUrl} download aria-label="Descargar CV en PDF">
          <IconCV />
          CV
        </a>
      </div>
    </div>

    <main id="main-content">

      <section class="hero" aria-label="Presentación">
        <p class="hero-eyebrow" id="he">✦ Miguel Ángel Ramírez · Desarrollador Multiplataforma</p>
        <h1 class="hero-title" id="ht">
          Construyo
          <span class="line2">productos<span class="accent" aria-hidden="true">.</span></span>
        </h1>
        <div class="hero-bottom" id="hb">
          <p class="hero-desc">Frontend sólido, arquitectura pensada. Del web al móvil con KMP.</p>
          <div class="hero-scroll" aria-hidden="true">
            <div class="scroll-line"></div>
            <span>Scroll</span>
          </div>
        </div>
      </section>

      <div class="marquee-wrap" aria-hidden="true">
        <div class="marquee-track" id="marquee-track">
          {marqueeItems.map((item) => (
            <span class="marquee-item">{item}</span>
          ))}
        </div>
      </div>

      <div class="content">

        <section class="section" id="sobre-mi" aria-labelledby="title-sobre-mi">
          <div class="section-header reveal">
            <span class="section-num" aria-hidden="true">01 / Sobre mí</span>
            <h2 class="section-title" id="title-sobre-mi">Quién soy</h2>
          </div>
          <div class="about-grid">
            <div class="about-left reveal">
              <p class="about-statement">
                Hola, soy <em>Miguel Ángel Ramírez Pérez</em>.
                Construyo productos digitales
                desde <em>frontend</em> hasta <em>multiplataforma</em>.
              </p>
              <p class="about-bio">
                Estudié DAM en el IES Celia Viñas de Almería. Aprendí a programar de verdad: algoritmos, estructuras de datos, lógica sin atajos. Después aterricé en el frontend y encontré el lugar donde esa base importa más: interfaces que no solo se ven bien, sino que están bien construidas. Hoy trabajo en Farmacias.com y en paralelo desarrollo Vexelplaypro, mi proyecto propio, que ya camina hacia móvil con Kotlin Multiplatform.
              </p>
              <div class="about-links">
                <a href="https://github.com/marp0604" target="_blank" rel="noopener noreferrer" class="about-link" aria-label="Perfil de GitHub (abre en nueva pestaña)">
                  <IconGitHub />
                  GitHub
                </a>
                <a href="https://linkedin.com/in/marp0604" target="_blank" rel="noopener noreferrer" class="about-link" aria-label="Perfil de LinkedIn (abre en nueva pestaña)">
                  <IconLinkedIn />
                  LinkedIn
                </a>
                <a href={cvUrl} download class="about-link about-link-cv" aria-label="Descargar CV en PDF">
                  <IconCV />
                  Descargar CV
                </a>
              </div>
            </div>

            <div class="about-right reveal">
              <div class="about-photo-wrap">
                <img
                  src="/perfil.jpg"
                  alt="Miguel Ángel Ramírez Pérez — Desarrollador Multiplataforma"
                  width="380"
                  height="507"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="about-details">
                <div class="about-detail-item">
                  <p class="about-detail-label">Rol</p>
                  <p class="about-detail-value">Desarrollador Multiplataforma</p>
                </div>
                <div class="about-detail-item">
                  <p class="about-detail-label">Stack</p>
                  <p class="about-detail-value">Astro · React · TypeScript · KMP</p>
                </div>
                <div class="about-detail-item">
                  <p class="about-detail-label">Ubicación</p>
                  <p class="about-detail-value">Almería, España</p>
                </div>
                <div class="about-detail-item">
                  <p class="about-detail-label">Empresa</p>
                  <p class="about-detail-value">Farmacias.com · Presente</p>
                </div>
                <div class="about-detail-item">
                  <p class="about-detail-label">Email</p>
                  <p class="about-detail-value" id="email-display">
                    <noscript><a href="mailto:contacto&#64;marp0604&#46;com">contacto&#64;marp0604&#46;com</a></noscript>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="experiencia" aria-labelledby="title-experiencia">
          <div class="section-header reveal">
            <span class="section-num" aria-hidden="true">02 / Trayectoria</span>
            <h2 class="section-title" id="title-experiencia">Experiencia</h2>
          </div>
          <div class="exp-list">
            {experiencia.map((e) => (
              <div class="exp-item reveal">
                <div>
                  <p class="exp-empresa">{e.empresa}</p>
                  <p class="exp-rol">{e.rol}</p>
                  <p class="exp-desc">{e.descripcion}</p>
                </div>
                <div class="exp-meta">
                  <span class="exp-periodo">{e.periodo}</span>
                  <span class="exp-ubicacion">{e.ubicacion}</span>
                </div>
              </div>
            ))}
          </div>

          <div class="edu-block">
            <p class="section-num edu-block-label">Formación</p>
            <div class="edu-list">
              {formacion.map((f) => (
                <div class="edu-item reveal">
                  <div>
                    <p class="edu-titulo">{f.titulo}</p>
                    <p class="edu-centro">{f.centro}</p>
                  </div>
                  <p class="edu-periodo">{f.periodo}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="section" id="proyectos" aria-labelledby="title-proyectos">
          <div class="section-header reveal">
            <span class="section-num" aria-hidden="true">03 / Trabajo</span>
            <h2 class="section-title" id="title-proyectos">Proyectos</h2>
          </div>
          <div>
            {proyectos.map((p) => (
              <article class="proyecto-item reveal">
                <span class="proyecto-num" aria-hidden="true">{p.num}</span>
                <div class="proyecto-info">
                  <div class="proyecto-title-row">
                    <span class="proyecto-name">{p.titulo}</span>
                    {p.wip && <span class="proyecto-badge">En progreso</span>}
                  </div>
                  <div class="proyecto-tags">
                    {p.tecnologias.map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  <p class="proyecto-desc">{p.descripcion}</p>
                  <div class="proyecto-links">
                    {p.links.map((l) => (
                      <a
                        href={l.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="proyecto-link"
                        aria-label={`${l.label} de ${p.titulo} (abre en nueva pestaña)`}
                      >
                        {l.tipo === "repo" && <IconGitHub />}
                        <span>{l.label}</span>
                        <span class="proyecto-link-arrow" aria-hidden="true">↗</span>
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="stack" aria-labelledby="title-stack">
          <div class="section-header reveal">
            <span class="section-num" aria-hidden="true">04 / Herramientas</span>
            <h2 class="section-title" id="title-stack">Stack</h2>
          </div>
          <div class="stack-grupos reveal">
            {stackGrupos.map((g) => (
              <div class="stack-grupo">
                <p class="stack-grupo-label">{g.categoria}</p>
                <div class="stack-chips">
                  {g.skills.map((s) => (
                    <span class={`chip${s === "Astro" || s === "React" || s === "TypeScript" ? " chip-accent" : ""}`}>{s}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="contact-big" id="contacto" aria-labelledby="title-contacto">
          <p class="contact-overline reveal">05 / Contacto</p>
          <h2 class="contact-title reveal" id="title-contacto">
            Hablemos
            <span>de tu proyecto.</span>
          </h2>
          <div class="contact-actions reveal">
            <button id="contact-btn" class="contact-email" type="button">
              <span id="contact-btn-text">Enviar email</span>
              <span class="arrow" aria-hidden="true">↗</span>
            </button>
            <noscript>
              <a class="contact-email" href="mailto:contacto&#64;marp0604&#46;com">
                contacto&#64;marp0604&#46;com
                <span class="arrow" aria-hidden="true">↗</span>
              </a>
            </noscript>
            <a
              href="https://linkedin.com/in/marp0604"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-linkedin"
              aria-label="LinkedIn (abre en nueva pestaña)"
            >
              <IconLinkedIn size={16} />
              LinkedIn
            </a>
            <a href={cvUrl} download class="contact-linkedin" aria-label="Descargar CV en PDF">
              <IconCV size={16} />
              Descargar CV
            </a>
          </div>
        </section>

      </div>

    </main>

    <footer>
      <span>© 2026 Miguel Ángel Ramírez Pérez</span>
      <a
        href="https://github.com/marp0604/marp0604-portfolio"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-github"
        aria-label="Código fuente en GitHub (abre en nueva pestaña)"
      >
        <IconGitHub />
        Código fuente
      </a>
    </footer>

    <script>
      import '../scripts/main.js';
    </script>

  </body>
</html>
