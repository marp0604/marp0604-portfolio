---
const nombre = "Miguel Ángel";
const rol = "Desarrollador Web";
const descripcion = "Construyo experiencias web modernas, limpias y funcionales. Apasionado por el código limpio y el buen diseño.";

const proyectos = [
  {
    titulo: "marp0604-portfolio",
    descripcion: "Portfolio personal construido con Astro. Diseño de alto impacto visual con animaciones CSS y canvas.",
    tecnologias: ["Astro", "CSS", "TypeScript"],
    url: "https://github.com/marp0604/marp0604-portfolio",
    num: "01",
  },
];

const stack = [
  { nombre: "HTML",       nivel: 95 },
  { nombre: "CSS",        nivel: 92 },
  { nombre: "JavaScript", nivel: 88 },
  { nombre: "TypeScript", nivel: 80 },
  { nombre: "Astro",      nivel: 85 },
  { nombre: "React",      nivel: 78 },
  { nombre: "Node.js",    nivel: 72 },
  { nombre: "Git",        nivel: 90 },
];

const marqueeItems = [
  "Diseño Web", "Frontend", "Astro", "React", "TypeScript",
  "Node.js", "CSS", "UI/UX",
];
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={descripcion} />
    <title>{nombre} · {rol}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:       #080808;
        --surface:  #111111;
        --border:       rgba(255,255,255,0.07);
        --border-hover: rgba(255,255,255,0.18);
        --text:   #f2f0ec;
        --muted:  #a0a09a;
        --accent:  #c8f060;
        --accent2: #60d0f0;
        --font-body:    'Inter', system-ui, sans-serif;
        --font-display: 'Syne', sans-serif;
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
        --text-xs:   clamp(0.75rem,  0.7rem  + 0.25vw, 0.8125rem);
        --text-sm:   clamp(0.875rem, 0.85rem + 0.25vw, 0.9375rem);
        --text-base: clamp(1rem,     0.95rem + 0.25vw, 1.0625rem);
        --text-lg:   clamp(1.125rem, 1rem    + 0.5vw,  1.375rem);
        --text-hero: clamp(3.5rem,   0.5rem  + 8vw,    9rem);
      }

      html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        cursor: none;
      }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--text);
        font-size: var(--text-base);
        line-height: 1.7;
        overflow-x: hidden;
      }

      /* CURSOR */
      #cursor {
        position: fixed; width: 10px; height: 10px;
        background: var(--accent); border-radius: 50%;
        pointer-events: none; z-index: 9999;
        transform: translate(-50%,-50%);
        transition: width 300ms var(--ease), height 300ms var(--ease);
        mix-blend-mode: difference;
      }
      #cursor-ring {
        position: fixed; width: 36px; height: 36px;
        border: 1.5px solid rgba(200,240,96,0.45); border-radius: 50%;
        pointer-events: none; z-index: 9998;
        transform: translate(-50%,-50%);
        transition: width 300ms var(--ease), height 300ms var(--ease);
      }
      body:has(a:hover) #cursor,
      body:has(button:hover) #cursor { width: 18px; height: 18px; }
      body:has(a:hover) #cursor-ring,
      body:has(button:hover) #cursor-ring { width: 56px; height: 56px; }

      /* CANVAS */
      #hero-canvas {
        position: fixed; top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none; z-index: 0;
        opacity: 0.22;
      }

      /* NAV */
      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        display: flex; justify-content: space-between; align-items: center;
        padding: 1.5rem 3rem;
        background: rgba(8,8,8,0.80);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
      }
      .nav-logo {
        font-family: var(--font-display); font-size: var(--text-base);
        font-weight: 800; color: var(--text);
        text-decoration: none; letter-spacing: 0.08em; text-transform: uppercase;
      }
      .nav-links { display: flex; gap: 2.5rem; list-style: none; }
      .nav-links a {
        color: var(--muted); text-decoration: none;
        font-size: var(--text-sm); letter-spacing: 0.08em;
        text-transform: uppercase; font-weight: 500;
        transition: color 200ms;
      }
      .nav-links a:hover { color: var(--text); }

      /* HERO */
      .hero {
        position: relative; z-index: 1;
        min-height: 100vh;
        display: flex; flex-direction: column; justify-content: flex-end;
        padding: 0 3rem 5rem;
        max-width: 1400px; margin: 0 auto;
      }
      .hero-eyebrow {
        font-size: var(--text-sm); letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--accent);
        font-weight: 600; margin-bottom: 1.5rem;
        opacity: 0; transform: translateY(16px);
        transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
      }
      .hero-title {
        font-family: var(--font-display);
        font-size: var(--text-hero);
        font-weight: 800; line-height: 0.95;
        letter-spacing: -0.04em; color: var(--text);
        margin-bottom: 2.5rem;
        opacity: 0; transform: translateY(16px);
        transition: opacity 0.7s 0.15s var(--ease), transform 0.7s 0.15s var(--ease);
      }
      .hero-bottom {
        display: flex; justify-content: space-between;
        align-items: flex-end; gap: 2rem; flex-wrap: wrap;
        opacity: 0; transform: translateY(16px);
        transition: opacity 0.7s 0.3s var(--ease), transform 0.7s 0.3s var(--ease);
      }
      .hero-eyebrow.show, .hero-title.show, .hero-bottom.show {
        opacity: 1; transform: translateY(0);
      }
      .hero-title .line2 {
        display: block;
        -webkit-text-stroke: 1.5px rgba(255,255,255,0.4);
        color: transparent;
        transition: color 400ms, -webkit-text-stroke 400ms;
      }
      .hero-title .line2:hover { color: var(--text); -webkit-text-stroke: 0px; }
      .hero-title .accent { color: var(--accent); }
      .hero-desc {
        font-size: var(--text-base); color: var(--text);
        max-width: 380px; line-height: 1.75; opacity: 0.82;
      }
      .hero-scroll {
        display: flex; flex-direction: column;
        align-items: center; gap: 0.5rem;
        color: var(--muted); font-size: var(--text-xs);
        letter-spacing: 0.15em; text-transform: uppercase; font-weight: 500;
      }
      .scroll-line {
        width: 1px; height: 60px;
        background: linear-gradient(to bottom, var(--accent), transparent);
        animation: scrollPulse 2.5s ease-in-out infinite;
      }

      /* MARQUEE
         La duración base (100s) es solo un fallback.
         JS la sobreescribe calculando: duración = (anchoMitad / 80) segundos
         para mantener siempre ~80px/s independientemente del tamaño de pantalla.
      */
      .marquee-wrap {
        position: relative; z-index: 1;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        overflow: hidden; padding: 1.1rem 0;
        background: var(--surface);
      }
      .marquee-track {
        display: flex; gap: 4rem; white-space: nowrap; width: max-content;
        animation: marquee 100s linear infinite;
      }
      .marquee-track:hover { animation-play-state: paused; }
      .marquee-item {
        font-family: var(--font-display);
        font-size: var(--text-sm); font-weight: 700;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--muted);
        display: flex; align-items: center; gap: 4rem;
      }
      .marquee-item::after {
        content: ''; width: 4px; height: 4px; border-radius: 50%;
        background: var(--accent); flex-shrink: 0; display: inline-block;
      }

      /* CONTENT */
      .content {
        position: relative; z-index: 1;
        max-width: 1400px; margin: 0 auto; padding: 0 3rem;
      }
      .section { padding: 8rem 0; border-top: 1px solid var(--border); }
      .section-header {
        display: flex; justify-content: space-between;
        align-items: baseline; margin-bottom: 5rem;
      }
      .section-num {
        font-family: var(--font-display); font-size: var(--text-xs);
        color: var(--muted); letter-spacing: 0.12em;
        font-weight: 700; text-transform: uppercase;
      }
      .section-title {
        font-family: var(--font-display);
        font-size: clamp(2.25rem, 5vw, 4.5rem);
        font-weight: 800; letter-spacing: -0.03em;
        color: var(--text); line-height: 1;
      }

      /* SOBRE MI */
      .about-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 6rem; align-items: start;
      }
      .about-text-large {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 2.5vw, 2.125rem);
        font-weight: 700; line-height: 1.35;
        color: var(--text); letter-spacing: -0.02em;
      }
      .about-text-large em { color: var(--accent); font-style: normal; }
      .about-details { display: flex; flex-direction: column; gap: 1.75rem; }
      .about-detail-item { border-top: 1px solid var(--border); padding-top: 1.25rem; }
      .about-detail-label {
        font-size: var(--text-xs); letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--muted);
        margin-bottom: 0.35rem; font-weight: 600;
      }
      .about-detail-value {
        font-size: var(--text-base); color: var(--text);
        font-weight: 500; line-height: 1.5;
      }

      /* PROYECTOS */
      .proyecto-item {
        display: grid; grid-template-columns: 64px 1fr 2rem;
        gap: 3rem; align-items: center;
        padding: 2.5rem 0; border-top: 1px solid var(--border);
        text-decoration: none; position: relative; overflow: hidden;
      }
      .proyecto-item::after {
        content: ''; position: absolute;
        bottom: 0; left: 0; right: 0; height: 1px;
        background: var(--accent);
        transform: scaleX(0); transform-origin: left;
        transition: transform 400ms var(--ease);
      }
      .proyecto-item:hover::after { transform: scaleX(1); }
      .proyecto-item:hover .proyecto-num { color: var(--accent); }
      .proyecto-item:hover .proyecto-arrow { transform: translate(3px,-3px); color: var(--accent); }
      .proyecto-num {
        font-family: var(--font-display); font-size: var(--text-sm);
        color: var(--muted); font-weight: 700;
        letter-spacing: 0.06em; transition: color 280ms;
        font-variant-numeric: tabular-nums;
      }
      .proyecto-info { min-width: 0; }
      .proyecto-title-row {
        display: flex; align-items: center;
        gap: 1.25rem; margin-bottom: 0.5rem; flex-wrap: wrap;
      }
      .proyecto-name {
        font-family: var(--font-display);
        font-size: clamp(1.25rem, 2.5vw, 1.875rem);
        font-weight: 800; color: var(--text); letter-spacing: -0.025em;
      }
      .proyecto-tags2 { display: flex; gap: 0.375rem; flex-wrap: wrap; }
      .tag2 {
        font-size: var(--text-xs); padding: 0.2rem 0.65rem;
        border-radius: 999px; border: 1px solid var(--border-hover);
        color: var(--muted); font-weight: 600;
        letter-spacing: 0.04em; font-family: var(--font-body);
      }
      .proyecto-desc2 {
        font-size: var(--text-base); color: var(--muted);
        line-height: 1.7; max-width: 520px;
      }
      .proyecto-arrow {
        font-size: 1.25rem; color: var(--muted);
        transition: transform 280ms var(--ease), color 280ms;
        flex-shrink: 0; line-height: 1;
      }

      /* STACK */
      .stack-list { display: flex; flex-direction: column; }
      .stack-row {
        display: grid; grid-template-columns: 160px 1fr 52px;
        align-items: center; gap: 2rem;
        padding: 1.5rem 0; border-top: 1px solid var(--border);
      }
      .stack-name {
        font-family: var(--font-display); font-size: var(--text-base);
        font-weight: 700; color: var(--text); letter-spacing: -0.01em;
      }
      .stack-bar-bg {
        height: 3px; background: rgba(255,255,255,0.08);
        border-radius: 999px; overflow: hidden;
      }
      .stack-bar-fill {
        height: 100%;
        background: linear-gradient(to right, var(--accent), var(--accent2));
        border-radius: 999px;
        transform: scaleX(0); transform-origin: left;
        transition: transform 1.1s var(--ease);
      }
      .stack-bar-fill.visible { transform: scaleX(1); }
      .stack-pct {
        font-size: var(--text-sm); color: var(--muted);
        font-weight: 600; text-align: right;
        font-variant-numeric: tabular-nums;
        font-feature-settings: "tnum";
        letter-spacing: 0;
      }

      /* CONTACTO */
      .contact-big {
        padding: 8rem 0 10rem; border-top: 1px solid var(--border);
        text-align: center;
      }
      .contact-overline {
        font-size: var(--text-sm); letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--accent);
        font-weight: 700; margin-bottom: 2.25rem;
      }
      .contact-title {
        font-family: var(--font-display);
        font-size: clamp(3rem, 8vw, 7rem);
        font-weight: 800; letter-spacing: -0.04em;
        line-height: 1; color: var(--text); margin-bottom: 3rem;
      }
      .contact-title span {
        display: block;
        -webkit-text-stroke: 1.5px rgba(255,255,255,0.35);
        color: transparent;
      }
      .contact-email {
        display: inline-flex; align-items: center; gap: 0.875rem;
        font-family: var(--font-display); font-size: var(--text-lg);
        font-weight: 700; color: var(--text); text-decoration: none;
        border: 1.5px solid var(--border-hover);
        padding: 1.125rem 2.5rem; border-radius: 999px;
        transition: border-color 300ms, background 300ms, color 300ms;
        letter-spacing: -0.01em;
      }
      .contact-email:hover {
        border-color: var(--accent); background: var(--accent); color: #060606;
      }
      .contact-email .arrow { transition: transform 280ms var(--ease); }
      .contact-email:hover .arrow { transform: translate(3px,-3px); }

      /* FOOTER */
      footer {
        position: relative; z-index: 1;
        border-top: 1px solid var(--border);
        padding: 2rem 3rem;
        display: flex; justify-content: space-between; align-items: center;
        font-size: var(--text-sm); color: var(--muted); letter-spacing: 0.04em;
      }

      /* REVEAL */
      .reveal {
        opacity: 0; transform: translateY(28px);
        transition: opacity 0.65s var(--ease), transform 0.65s var(--ease);
      }
      .reveal.visible { opacity: 1; transform: translateY(0); }

      @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      @keyframes scrollPulse {
        0%, 100% { opacity: 0.3; }
        50%       { opacity: 1;   }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }

      @media (max-width: 768px) {
        nav { padding: 1.125rem 1.5rem; }
        .nav-links { display: none; }
        .hero { padding: 0 1.5rem 4rem; }
        .content { padding: 0 1.5rem; }
        .about-grid { grid-template-columns: 1fr; gap: 3rem; }
        .proyecto-item { grid-template-columns: 52px 1fr; gap: 1.5rem; }
        .proyecto-arrow { display: none; }
        .stack-row { grid-template-columns: 130px 1fr 44px; gap: 1.25rem; }
        .contact-big { padding: 5rem 0 6rem; }
        footer { padding: 1.5rem; flex-direction: column; gap: 0.5rem; text-align: center; }
      }
      @media (max-width: 480px) {
        html { cursor: auto; }
        #cursor, #cursor-ring { display: none; }
        .stack-row { grid-template-columns: 110px 1fr 40px; gap: 1rem; }
      }
    </style>
  </head>
  <body>

    <div id="cursor"></div>
    <div id="cursor-ring"></div>
    <canvas id="hero-canvas"></canvas>

    <nav>
      <a href="/" class="nav-logo">MA</a>
      <ul class="nav-links">
        <li><a href="#sobre-mi">Sobre mí</a></li>
        <li><a href="#proyectos">Proyectos</a></li>
        <li><a href="#stack">Stack</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
    </nav>

    <section class="hero">
      <p class="hero-eyebrow" id="he">✦ Disponible para proyectos</p>
      <h1 class="hero-title" id="ht">
        Construyo
        <span class="line2">el futuro<span class="accent">.</span></span>
      </h1>
      <div class="hero-bottom" id="hb">
        <p class="hero-desc">{descripcion}</p>
        <div class="hero-scroll">
          <div class="scroll-line"></div>
          <span>Scroll</span>
        </div>
      </div>
    </section>

    <div class="marquee-wrap">
      <div class="marquee-track" id="marquee-track">
        {[...marqueeItems, ...marqueeItems].map((item) => (
          <span class="marquee-item">{item}</span>
        ))}
      </div>
    </div>

    <div class="content">

      <section class="section" id="sobre-mi">
        <div class="section-header reveal">
          <span class="section-num">01 / Sobre mí</span>
          <h2 class="section-title">Quién soy</h2>
        </div>
        <div class="about-grid">
          <p class="about-text-large reveal">
            Soy <em>Miguel Ángel</em>, desarrollador web
            con pasión por crear productos digitales
            que funcionen bien <em>y se vean mejor</em>.
          </p>
          <div class="about-details reveal">
            <div class="about-detail-item">
              <p class="about-detail-label">Especialidad</p>
              <p class="about-detail-value">Frontend &amp; Fullstack</p>
            </div>
            <div class="about-detail-item">
              <p class="about-detail-label">Disponibilidad</p>
              <p class="about-detail-value">Freelance &amp; Proyectos</p>
            </div>
            <div class="about-detail-item">
              <p class="about-detail-label">Ubicación</p>
              <p class="about-detail-value">España</p>
            </div>
            <div class="about-detail-item">
              <p class="about-detail-label">Email</p>
              <p class="about-detail-value">contacto@marp0604.com</p>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="proyectos">
        <div class="section-header reveal">
          <span class="section-num">02 / Trabajo</span>
          <h2 class="section-title">Proyectos</h2>
        </div>
        <div>
          {proyectos.map((p) => (
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="proyecto-item reveal">
              <span class="proyecto-num">{p.num}</span>
              <div class="proyecto-info">
                <div class="proyecto-title-row">
                  <span class="proyecto-name">{p.titulo}</span>
                  <div class="proyecto-tags2">
                    {p.tecnologias.map((t) => <span class="tag2">{t}</span>)}
                  </div>
                </div>
                <p class="proyecto-desc2">{p.descripcion}</p>
              </div>
              <span class="proyecto-arrow">↗</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section" id="stack">
        <div class="section-header reveal">
          <span class="section-num">03 / Tecnologías</span>
          <h2 class="section-title">Stack</h2>
        </div>
        <div class="stack-list">
          {stack.map((s) => (
            <div class="stack-row reveal">
              <span class="stack-name">{s.nombre}</span>
              <div class="stack-bar-bg">
                <div class="stack-bar-fill" style={`width: ${s.nivel}%`}></div>
              </div>
              <span class="stack-pct">{s.nivel}%</span>
            </div>
          ))}
        </div>
      </section>

      <div class="contact-big" id="contacto">
        <p class="contact-overline reveal">✦ Hablemos</p>
        <h2 class="contact-title reveal">
          ¿Tienes un proyecto
          <span>en mente?</span>
        </h2>
        <a href="mailto:contacto@marp0604.com" class="contact-email reveal">
          contacto@marp0604.com
          <span class="arrow">↗</span>
        </a>
      </div>

    </div>

    <footer>
      <span>© {new Date().getFullYear()} Miguel Ángel</span>
      <span>Hecho con Astro ✦</span>
    </footer>

    <script>
      // CURSOR
      const cursor = document.getElementById('cursor');
      const ring   = document.getElementById('cursor-ring');
      let mx = 0, my = 0, rx = 0, ry = 0;
      document.addEventListener('mousemove', (e) => {
        mx = e.clientX; my = e.clientY;
        cursor.style.left = mx + 'px';
        cursor.style.top  = my + 'px';
      });
      (function animRing() {
        rx += (mx - rx) * 0.10;
        ry += (my - ry) * 0.10;
        ring.style.left = rx + 'px';
        ring.style.top  = ry + 'px';
        requestAnimationFrame(animRing);
      })();

      // HERO ANIMATIONS
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.getElementById('he').classList.add('show');
          setTimeout(() => document.getElementById('ht').classList.add('show'), 150);
          setTimeout(() => document.getElementById('hb').classList.add('show'), 300);
        });
      });

      // MARQUEE: velocidad fija en px/s (independiente del ancho total del track)
      // Velocidad objetivo: 80px/s -> si el track mide 2000px, duracion = 2000/80 = 25s
      // Usamos scrollWidth/2 porque el track tiene los items duplicados (loop -50%)
      (function setMarqueeSpeed() {
        const PX_PER_SEC = 80; // ajusta este valor para cambiar la velocidad
        const track = document.getElementById('marquee-track');
        if (!track) return;
        // Esperamos a que el navegador haya calculado el ancho real
        requestAnimationFrame(() => {
          const halfWidth = track.scrollWidth / 2;
          const duration  = halfWidth / PX_PER_SEC;
          track.style.animationDuration = duration.toFixed(2) + 's';
        });
      })();

      // CANVAS
      const canvas = document.getElementById('hero-canvas');
      const ctx    = canvas.getContext('2d');
      let W = canvas.width  = window.innerWidth;
      let H = canvas.height = window.innerHeight;
      window.addEventListener('resize', () => {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
      });
      const N = 65;
      const pts = Array.from({ length: N }, () => ({
        x: Math.random()*W, y: Math.random()*H,
        vx: (Math.random()-0.5)*0.25, vy: (Math.random()-0.5)*0.25,
        r: Math.random()*1.1+0.3, a: Math.random()*0.45+0.15,
      }));
      function draw() {
        ctx.clearRect(0,0,W,H);
        for (const p of pts) {
          p.x+=p.vx; p.y+=p.vy;
          if(p.x<0||p.x>W) p.vx*=-1;
          if(p.y<0||p.y>H) p.vy*=-1;
          ctx.beginPath();
          ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
          ctx.fillStyle=`rgba(200,240,96,${p.a*0.5})`;
          ctx.fill();
        }
        for(let i=0;i<N;i++){
          for(let j=i+1;j<N;j++){
            const dx=pts[i].x-pts[j].x, dy=pts[i].y-pts[j].y;
            const d=Math.sqrt(dx*dx+dy*dy);
            if(d<100){
              ctx.beginPath();
              ctx.moveTo(pts[i].x,pts[i].y);
              ctx.lineTo(pts[j].x,pts[j].y);
              ctx.strokeStyle=`rgba(200,240,96,${(1-d/100)*0.09})`;
              ctx.lineWidth=0.5; ctx.stroke();
            }
          }
        }
        requestAnimationFrame(draw);
      }
      draw();

      // SCROLL REVEAL
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if(e.isIntersecting){
            e.target.classList.add('visible');
            const fill = e.target.querySelector('.stack-bar-fill');
            if(fill) setTimeout(()=>fill.classList.add('visible'),80);
          }
        });
      },{ threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el)=>obs.observe(el));
    </script>

  </body>
</html>
