---
interface Props {
  size?: number;
  class?: string;
}
const { size = 22, class: className = "" } = Astro.props;
---
<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 200 200"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M40,160 L40,40 L100,110 L160,40 L160,160"
    fill="none"
    stroke="currentColor"
    stroke-width="24"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
